# RPIN Environment Configuration
# Copy this file to .env and fill in your actual values

# Project Settings
PROJECT_NAME="RPIN - Rural Producer Intelligence Network"
VERSION="1.0.0"
LOG_LEVEL="INFO"

# External API Keys
OPENWEATHER_API_KEY=your_openweather_api_key_here
LLM_API_KEY=your_llm_api_key_here

# Database
DATABASE_URL=sqlite:///./rpin.db

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Model Settings
ENABLE_MODEL_CACHING=true
MODEL_CACHE_DIR=./models

# Data Directories
DATA_DIR=./data
CROPS_DATA_FILE=./data/crops.json
MARKETS_DATA_FILE=./data/markets.json
DISTANCES_DATA_FILE=./data/distances.json

# Prediction Settings
FORECAST_DAYS=7
MIN_MARKETS_TO_ANALYZE=3
MAX_TRANSPORT_DISTANCE_KM=500

# Transport Cost (INR per km per quintal)
TRANSPORT_COST_PER_KM_MIN=3.0
TRANSPORT_COST_PER_KM_MAX=5.0

# Performance
REQUEST_TIMEOUT_SECONDS=30
CACHE_TTL_HOURS=24
MAX_RESPONSE_TIME_SECONDS=10
